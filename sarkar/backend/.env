# =============================================================================
# CleanAir-Tracker BACKEND environment file
# Location: backend/.env  (same folder as Dockerfile, requirements.txt)
# Already in .gitignore. Never commit this file. Never paste real values
# from it into a chat, ticket, or Slack — treat any credential typed
# outside your local machine as compromised and rotate it immediately.
# =============================================================================

# --- Firebase / Firestore ---
# Path to the service account JSON downloaded from:
# Firebase Console -> Project Settings -> Service Accounts -> Generate
# new private key. This exact variable name (GOOGLE_APPLICATION_CREDENTIALS)
# is what database.py reads via os.getenv() — do not rename this key
# without also changing database.py, or Firebase init will silently
# fall through to firebase_admin.initialize_app() with no credentials.
#
# IMPORTANT: if you rotated your Firebase key (you should have, after
# uploading the old one to a chat), make sure this filename still points
# at your NEW service account JSON, not the old rotated-out one.
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# --- Gemini AI (classification + before/after verification) ---
# aistudio.google.com -> Get API key. Leave blank to run in
# GEMINI_MOCK_MODE (config.py falls back automatically — no code change
# needed either way).
GEMINI_API_KEY=AQ.Ab8RN6IqkkGPcTKPXVKm51bbl442MrMqLOsvGJwO_lpZxDgMMA
GEMINI_MODEL=gemini-2.0-flash

# --- Citizen verification token (JWT) ---
# This section was MISSING from your .env entirely — auth.py needs it
# to sign verification tokens. Generate a real value locally with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# Do NOT reuse SMTP_PASSWORD here — see auth.py's comments on why
# these secrets are kept separate.
JWT_SECRET_KEY=ccac81fea0179aaf9b8b8ab3791a8d0f6916d302f9fa094c8003626d9ee63fd9
# Optional — defaults to 120 (2 hours) in config.py if omitted:
# VERIFICATION_TOKEN_EXPIRE_MINUTES=120

# --- Cloudinary (photo storage) --- [UNUSED — see note]
# storage.py does NOT call Cloudinary. It base64-encodes photos directly
# into Firestore documents (see storage.py's upload_evidence_to_cloud).
# Setting this does nothing unless storage.py is rewired to use it.
# Safe to delete this line, or leave blank — either way, no effect.
CLOUDINARY_URL=

# --- OpenWeatherMap (air quality data) --- [UNUSED — see note]
# weather.py and forecast_geocode.py both call Open-Meteo, which needs
# NO API key at all. Nothing in this codebase reads this variable.
# Safe to delete this line, or leave blank — either way, no effect.
OPENWEATHERMAP_API_KEY=038096ae4427de0440298dd6b674fbf7

# --- SMTP (email OTP delivery) ---
# Using Gmail SMTP here: SMTP_USERNAME is your full Gmail address,
# SMTP_PASSWORD is a 16-character App Password (NOT your normal Gmail
# password) — generate one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the account first). If either
# of these is blank, auth.py falls back to the hardcoded "123456" OTP
# bypass for demo use (see SMTP_MOCK_MODE in config.py).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=PASTE_YOUR_GMAIL_ADDRESS_HERE
SMTP_PASSWORD=PASTE_YOUR_16_CHAR_APP_PASSWORD_HERE
# Optional — defaults to SMTP_USERNAME if left blank:
# SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Saaf Sarkar

# --- Google Sign-In (web) ---
# console.cloud.google.com/apis/credentials -> Create OAuth client ID ->
# Application type: Web application. Add your deployed frontend origin
# (and http://localhost:PORT for local dev) under "Authorized JavaScript
# origins". Copy the Client ID here (ends in .apps.googleusercontent.com)
# — this is NOT secret, it's safe to also put in frontend JS. If this is
# blank, POST /api/auth/google-login returns 503 (see
# GOOGLE_LOGIN_ENABLED in config.py) — email OTP still works either way.
GOOGLE_CLIENT_ID=PASTE_YOUR_GOOGLE_OAUTH_CLIENT_ID_HERE

# --- Clustering thresholds (optional — safe defaults already in config.py) ---
CLUSTER_RADIUS_METERS=150.0
CLUSTER_TIME_WINDOW_HOURS=72.0

# --- Severity scoring (optional — safe defaults already in config.py) ---
SEVERITY_DUPLICATE_BONUS=10
SEVERITY_DUPLICATE_THRESHOLD=3
SEVERITY_SENSITIVE_ZONE_BONUS=15



TEAM_BYPASS_EMAILS=sidharthakuna@gmail.com,bob@yourteam.com
TEAM_BYPASS_CODE=123456

