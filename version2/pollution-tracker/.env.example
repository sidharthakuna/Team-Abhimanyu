# Copy this file to .env and fill in REAL values there. Never commit .env.
# Never paste real values from this file into a chat, ticket, or Slack —
# treat any credential that's been pasted somewhere outside your local
# machine as compromised and rotate it in the provider's console.

# --- Firebase / Firestore ---
# Path to the service account JSON file downloaded from:
# Firebase Console -> Project Settings -> Service Accounts -> Generate
# new private key. Save the downloaded file OUTSIDE the repo root (or
# somewhere already covered by .gitignore — see .gitignore in this repo,
# which already excludes firebase-credentials.json and *firebase-adminsdk*.json
# by name) and point this at it.
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
# Optional — only needed if it's not already embedded in the credentials
# file itself (it usually is, as project_id).
FIREBASE_PROJECT_ID=

# --- Cloudinary (photo storage) ---
# Single connection string from your Cloudinary dashboard (Dashboard ->
# API Environment variable), shaped like:
#   CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Copy that exact string from your dashboard and paste it below — don't
# type your cloud name / key / secret into this file separately.
CLOUDINARY_URL=



# --- Gemini (image classification + before/after verification) ---
# Leave blank to run in MOCK mode — the full pipeline still works end to
# end, classifications are just simulated. Get a free key from
# aistudio.google.com -> "Get API key", then paste it below and restart
# the app. No code changes needed either way.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- OpenWeatherMap (external air quality signal) ---
# Free key from openweathermap.org -> sign up -> API keys tab. Leave
# blank to have this signal show as unavailable (citizen-report risk
# score still works fine without it).
OPENWEATHERMAP_API_KEY=